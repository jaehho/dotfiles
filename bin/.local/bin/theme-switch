#!/bin/bash
# Switch theme by copying a preset to the active palette, then applying
# Usage: theme-switch [preset-name]
#   theme-switch forest
#   theme-switch catppuccin-frappe

set -euo pipefail

PRESETS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/theme/presets"
PALETTE="${XDG_CONFIG_HOME:-$HOME/.config}/theme/palette"

if [[ ! -d "$PRESETS_DIR" ]]; then
  echo "No presets found at $PRESETS_DIR" >&2
  exit 1
fi

PRESET="${1:-}"

if [[ -z "$PRESET" ]]; then
  CURRENT="(unknown)"
  if [[ -f "$PALETTE" ]]; then
    CURRENT=$(head -1 "$PALETTE" | sed 's/^# *//')
  fi
  echo "Current: $CURRENT"
  echo "Available presets:"
  for f in "$PRESETS_DIR"/*; do
    name=$(basename "$f")
    desc=$(head -1 "$f" | sed 's/^# *//')
    echo "  $name — $desc"
  done
  exit 0
fi

if [[ ! -f "$PRESETS_DIR/$PRESET" ]]; then
  echo "Unknown preset: $PRESET" >&2
  echo "Available: $(ls "$PRESETS_DIR" | tr '\n' ' ')" >&2
  exit 1
fi

# Check if already active
if [[ -f "$PALETTE" ]] && diff -q "$PRESETS_DIR/$PRESET" "$PALETTE" >/dev/null 2>&1; then
  echo "Already using $PRESET"
  exit 0
fi

echo "Switching to $PRESET..."
cp "$PRESETS_DIR/$PRESET" "$PALETTE"
theme-apply
