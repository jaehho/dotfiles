#!/usr/bin/env bash
# Desktop notification via Kitty OSC 99 — works locally and through SSH + tmux.
# Falls back to notify-send only when not in a terminal.
#
# Usage: notify "message"
#        notify "title" "message"
#        long-command; notify "done"

set -euo pipefail

if [ $# -ge 2 ]; then
    title="$1"; body="$2"
elif [ $# -eq 1 ]; then
    title=""; body="$1"
else
    echo "Usage: notify [title] message" >&2
    exit 1
fi

# Raw OSC 99 (bare Kitty, no tmux)
osc99() {
    if [ -n "$title" ]; then
        printf '\e]99;i=1:d=0:p=title;%s\a\e]99;i=1:p=body;%s\a' "$title" "$body"
    else
        printf '\e]99;i=1:p=body;%s\a' "$body"
    fi
}

# OSC 99 wrapped in DCS tmux passthrough
dcs_osc99() {
    if [ -n "$title" ]; then
        printf '\ePtmux;\e\e]99;i=1:d=0:p=title;%s\a\e\\\ePtmux;\e\e]99;i=1:p=body;%s\a\e\\' \
            "$title" "$body"
    else
        printf '\ePtmux;\e\e]99;i=1:p=body;%s\a\e\\' "$body"
    fi
}

if [ -n "${TMUX:-}" ]; then
    tty=$(tmux display-message -p '#{client_tty}' 2>/dev/null)
    if [ -n "${SSH_CONNECTION:-}" ] && [ -n "$tty" ]; then
        # Remote tmux over SSH: the DCS write bypasses remote tmux and goes
        # straight to SSH → local terminal.  Send BOTH raw and DCS-wrapped so
        # it works whether the local side is bare kitty or tmux+kitty.
        { osc99; dcs_osc99; } > "$tty"
    elif [ -n "$tty" ]; then
        # Local tmux: DCS-wrapped for tmux to pass through to kitty
        dcs_osc99 > "$tty"
    fi
elif [ -n "${SSH_CONNECTION:-}" ]; then
    # SSH without remote tmux: write to controlling terminal (/dev/tty goes
    # back through SSH to local terminal).  Send both formats.
    if [ -w /dev/tty ]; then
        { osc99; dcs_osc99; } > /dev/tty
    else
        notify-send ${title:+"$title"} "$body" 2>/dev/null || true
    fi
elif [ -t 1 ]; then
    # Bare terminal (no tmux, no SSH): raw OSC 99
    osc99
else
    # Not in a terminal: fall back to notify-send
    if [ -n "$title" ]; then
        notify-send "$title" "$body"
    else
        notify-send "$body"
    fi
fi
