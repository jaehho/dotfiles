#!/usr/bin/env bash
# Invoke the top notification's action (or dismiss if no action).
# Used by SUPER+. keybind.

top_json=$(makoctl list -j 2>/dev/null | jq -c '.[0]' 2>/dev/null)
[[ -z "$top_json" || "$top_json" == "null" ]] && exit 0

top_id=$(echo "$top_json" | jq -r '.id // empty')
[[ -z "$top_id" ]] && exit 0

# Signal watchers to skip focus-based auto-dismiss (prevents cascade)
date +%s > /tmp/hypr-notification-invoke
count_before=$(makoctl list -j 2>/dev/null | jq 'length')
makoctl invoke -n "$top_id" >/dev/null 2>&1
sleep 0.1
count_after=$(makoctl list -j 2>/dev/null | jq 'length')
[[ "$count_after" -ge "$count_before" ]] && makoctl dismiss -n "$top_id" >/dev/null 2>&1
