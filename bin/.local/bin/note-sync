#!/usr/bin/env python3
"""Sync local markdown notes to a Notion database."""

import json
import re
import sys
import urllib.request
import urllib.error
from pathlib import Path

NOTES_DIR = Path.home() / "notes"
CONFIG_FILE = Path.home() / ".config" / "note-sync" / "config"
SYNCED_FILE = NOTES_DIR / ".synced"
NOTION_API = "https://api.notion.com/v1"
NOTION_VERSION = "2022-06-28"


def load_config():
    if not CONFIG_FILE.exists():
        return {}
    config = {}
    for line in CONFIG_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            key, val = line.split("=", 1)
            config[key.strip()] = val.strip()
    return config


def notion_request(api_key, method, endpoint, body=None):
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Notion-Version": NOTION_VERSION,
        "Content-Type": "application/json",
    }
    data = json.dumps(body).encode() if body else None
    req = urllib.request.Request(
        f"{NOTION_API}/{endpoint}",
        data=data,
        headers=headers,
        method=method,
    )
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


# --- Setup ---

def setup():
    print("\n  note-sync setup\n")
    print("  1. Go to https://www.notion.so/profile/integrations")
    print("  2. Click 'New integration', name it, select workspace")
    print("  3. Copy the 'Internal Integration Secret'\n")

    api_key = input("  API key: ").strip()
    if not api_key:
        print("  Error: API key required.")
        sys.exit(1)

    print("\n  Now set up the database:")
    print("  1. Create a full-page database in Notion for your notes")
    print("  2. Share it with your integration (... > Connections)")
    print("  3. Copy the database ID from the URL:")
    print("     notion.so/<workspace>/<DATABASE_ID>?v=...\n")

    db_input = input("  Database ID or URL: ").strip()
    if not db_input:
        print("  Error: Database ID required.")
        sys.exit(1)
    # Extract 32-char hex ID from full URL or raw input
    match = re.search(r"([0-9a-f]{32})", db_input.replace("-", ""))
    if not match:
        print("  Error: Could not find a valid database ID.")
        sys.exit(1)
    db_id = match.group(1)

    print("\n  Testing connection...")
    try:
        data = notion_request(api_key, "GET", f"databases/{db_id}")
        title = "".join(t["plain_text"] for t in data.get("title", []))
        print(f"  Connected: {title or '(untitled)'}")
    except urllib.error.HTTPError as e:
        print(f"  Error {e.code}: check API key, database ID, and integration access.")
        sys.exit(1)

    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(f"NOTION_API_KEY={api_key}\nNOTION_DATABASE_ID={db_id}\n")
    CONFIG_FILE.chmod(0o600)
    print(f"  Saved to {CONFIG_FILE}")
    print("  Run 'note sync' to sync your notes.\n")


# --- Markdown to Notion blocks ---

def chunk_text(text, max_len=2000):
    if not text:
        return [" "]
    if len(text) <= max_len:
        return [text]
    return [text[i : i + max_len] for i in range(0, len(text), max_len)]


def rich_text(text):
    return [{"type": "text", "text": {"content": c}} for c in chunk_text(text)]


def make_block(block_type, text):
    return {"object": "block", "type": block_type, block_type: {"rich_text": rich_text(text)}}


def parse_markdown_to_blocks(content):
    blocks = []
    lines = content.split("\n")

    # Skip first heading — it becomes the page title
    i = 0
    if lines and lines[0].startswith("# "):
        i = 1
    if i < len(lines) and not lines[i].strip():
        i += 1

    while i < len(lines):
        line = lines[i]

        if not line.strip():
            i += 1
            continue

        # Fenced code block
        if line.strip().startswith("```"):
            lang = line.strip()[3:].strip() or "plain text"
            code_lines = []
            i += 1
            while i < len(lines) and not lines[i].strip().startswith("```"):
                code_lines.append(lines[i])
                i += 1
            i += 1
            for c in chunk_text("\n".join(code_lines)):
                blocks.append(
                    {
                        "object": "block",
                        "type": "code",
                        "code": {
                            "rich_text": [{"type": "text", "text": {"content": c}}],
                            "language": lang,
                        },
                    }
                )
            continue

        # Headings
        if line.startswith("### "):
            blocks.append(make_block("heading_3", line[4:]))
        elif line.startswith("## "):
            blocks.append(make_block("heading_2", line[3:]))
        elif line.startswith("# "):
            blocks.append(make_block("heading_1", line[2:]))
        # Todo items
        elif re.match(r"^\s*- \[[xX]\] ", line):
            text = re.sub(r"^\s*- \[[xX]\] ", "", line)
            blocks.append(
                {
                    "object": "block",
                    "type": "to_do",
                    "to_do": {"rich_text": rich_text(text), "checked": True},
                }
            )
        elif re.match(r"^\s*- \[ \] ", line):
            text = re.sub(r"^\s*- \[ \] ", "", line)
            blocks.append(
                {
                    "object": "block",
                    "type": "to_do",
                    "to_do": {"rich_text": rich_text(text), "checked": False},
                }
            )
        # Bullet list
        elif re.match(r"^\s*[-*] ", line):
            text = re.sub(r"^\s*[-*] ", "", line)
            blocks.append(make_block("bulleted_list_item", text))
        # Numbered list
        elif re.match(r"^\s*\d+\. ", line):
            text = re.sub(r"^\s*\d+\. ", "", line)
            blocks.append(make_block("numbered_list_item", text))
        # Block quote
        elif line.strip().startswith("> "):
            blocks.append(make_block("quote", line.strip()[2:]))
        # Divider
        elif line.strip() in ("---", "***", "___"):
            blocks.append({"object": "block", "type": "divider", "divider": {}})
        # Paragraph
        else:
            blocks.append(make_block("paragraph", line))

        i += 1

    return blocks


# --- Sync ---

def get_synced():
    if not SYNCED_FILE.exists():
        return set()
    return set(SYNCED_FILE.read_text().splitlines())


def mark_synced(filename):
    with open(SYNCED_FILE, "a") as f:
        f.write(filename + "\n")


def extract_title(content, filename):
    for line in content.split("\n"):
        if line.startswith("# "):
            return line[2:].strip()
    return Path(filename).stem


def extract_date(filename):
    match = re.match(r"(\d{4}-\d{2}-\d{2})", filename)
    return match.group(1) if match else None


def sync(force=False):
    config = load_config()
    api_key = config.get("NOTION_API_KEY")
    db_id = config.get("NOTION_DATABASE_ID")

    if not api_key or not db_id:
        print("Not configured. Run 'note setup' first.")
        sys.exit(1)

    if not NOTES_DIR.exists():
        print("No notes found.")
        return

    # Read database schema to detect property names
    try:
        db = notion_request(api_key, "GET", f"databases/{db_id}")
    except urllib.error.HTTPError as e:
        print(f"Failed to access database: {e.code}")
        sys.exit(1)

    props = db.get("properties", {})
    title_prop = next((n for n, p in props.items() if p["type"] == "title"), "Name")
    date_prop = next((n for n, p in props.items() if p["type"] == "date"), None)

    synced = set() if force else get_synced()
    notes = sorted(NOTES_DIR.glob("*.md"))
    unsynced = [n for n in notes if n.name not in synced]

    if not unsynced:
        print("All notes are synced.")
        return

    print(f"Syncing {len(unsynced)} note(s)...\n")

    ok = 0
    for note_path in unsynced:
        content = note_path.read_text()
        if not content.strip():
            continue

        title = extract_title(content, note_path.name)
        date = extract_date(note_path.name)
        blocks = parse_markdown_to_blocks(content)

        properties = {
            title_prop: {"title": [{"type": "text", "text": {"content": title}}]},
        }
        if date_prop and date:
            properties[date_prop] = {"date": {"start": date}}

        try:
            result = notion_request(
                api_key,
                "POST",
                "pages",
                {
                    "parent": {"database_id": db_id},
                    "properties": properties,
                    "children": blocks[:100],
                },
            )

            # Append remaining blocks in batches of 100
            page_id = result["id"]
            remaining = blocks[100:]
            while remaining:
                notion_request(
                    api_key, "PATCH", f"blocks/{page_id}/children", {"children": remaining[:100]}
                )
                remaining = remaining[100:]

            mark_synced(note_path.name)
            print(f"  synced  {note_path.name}")
            ok += 1
        except urllib.error.HTTPError as e:
            try:
                err = json.loads(e.read().decode())
                msg = err.get("message", str(e.code))
            except Exception:
                msg = str(e.code)
            print(f"  FAIL   {note_path.name}: {msg}")

    print(f"\nDone. {ok}/{len(unsynced)} synced.")


def main():
    if "--setup" in sys.argv:
        setup()
    elif "--force" in sys.argv or "--all" in sys.argv:
        sync(force=True)
    else:
        sync()


if __name__ == "__main__":
    main()
