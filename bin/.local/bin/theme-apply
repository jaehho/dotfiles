#!/bin/bash
# theme-apply — read ~/.config/theme/palette and propagate colors everywhere
# Generated include files go into the dotfiles repo; sed for non-includable configs.

set -euo pipefail

PALETTE="${XDG_CONFIG_HOME:-$HOME/.config}/theme/palette"
DOTFILES="${DOTFILES:-$HOME/dotfiles}"

if [[ ! -f "$PALETTE" ]]; then
  echo "No palette found at $PALETTE" >&2
  exit 1
fi

# ── Load palette ─────────────────────────────────────────────────────────────
declare -A C
while IFS='=' read -r key val; do
  [[ -z "$key" || "$key" =~ ^# ]] && continue
  C[$key]="$val"
done < "$PALETTE"

ROLES=(base mantle crust text subtext1 subtext0 surface0 surface1 surface2
       overlay0 overlay1 overlay2 blue lavender sapphire sky teal green
       yellow peach maroon red mauve pink flamingo rosewater)

for r in "${ROLES[@]}"; do
  if [[ -z "${C[$r]:-}" ]]; then
    echo "Missing color: $r" >&2; exit 1
  fi
done

hex() { echo "#${C[$1]}"; }

# Helper: convert hex to decimal RGB
hex2rgb() {
  local h="${C[$1]}"
  printf "%d, %d, %d" "0x${h:0:2}" "0x${h:2:2}" "0x${h:4:2}"
}

echo "Applying palette: $(head -1 "$PALETTE" | sed 's/^# *//')"

# ── 1. Kitty — include file ─────────────────────────────────────────────────
cat > "$DOTFILES/kitty/.config/kitty/colors.conf" << EOF
# Generated by theme-apply — do not edit
foreground              $(hex text)
background              $(hex base)
selection_foreground     $(hex base)
selection_background     $(hex rosewater)
cursor                  $(hex rosewater)
cursor_text_color       $(hex base)
url_color               $(hex blue)

# Tabs
active_tab_foreground   $(hex crust)
active_tab_background   $(hex mauve)
inactive_tab_foreground $(hex text)
inactive_tab_background $(hex surface0)

# Marks
mark1_foreground $(hex base)
mark1_background $(hex lavender)

# ANSI colors
color0  $(hex surface1)
color8  $(hex surface2)
color1  $(hex red)
color9  $(hex red)
color2  $(hex green)
color10 $(hex green)
color3  $(hex yellow)
color11 $(hex yellow)
color4  $(hex blue)
color12 $(hex blue)
color5  $(hex pink)
color13 $(hex pink)
color6  $(hex teal)
color14 $(hex teal)
color7  $(hex subtext1)
color15 $(hex subtext0)
EOF
echo "  kitty colors.conf"

# ── 2. Hyprland — include file ──────────────────────────────────────────────
cat > "$DOTFILES/hypr/.config/hypr/colors.conf" << EOF
# Generated by theme-apply — do not edit
\$clr_active_1 = rgba(${C[blue]}ee)
\$clr_active_2 = rgba(${C[green]}ee)
\$clr_inactive = rgba(${C[surface1]}ab)
\$clr_shadow   = rgba(${C[crust]}ee)
\$clr_base     = rgba(${C[base]}e6)
\$clr_surface0 = rgba(${C[surface0]}99)
\$clr_overlay0 = rgba(${C[overlay0]}4d)
\$clr_blue_dim = rgba(${C[blue]}4d)
EOF
echo "  hyprland colors.conf"

# ── 3. Rofi — include file ──────────────────────────────────────────────────
cat > "$DOTFILES/rofi/.config/rofi/colors.rasi" << EOF
/* Generated by theme-apply — do not edit */
* {
  rosewater: $(hex rosewater);
  flamingo: $(hex flamingo);
  pink: $(hex pink);
  mauve: $(hex mauve);
  red: $(hex red);
  maroon: $(hex maroon);
  peach: $(hex peach);
  yellow: $(hex yellow);
  green: $(hex green);
  teal: $(hex teal);
  sky: $(hex sky);
  sapphire: $(hex sapphire);
  blue: $(hex blue);
  lavender: $(hex lavender);
  text: $(hex text);
  subtext1: $(hex subtext1);
  subtext0: $(hex subtext0);
  overlay2: $(hex overlay2);
  overlay1: $(hex overlay1);
  overlay0: $(hex overlay0);
  surface2: $(hex surface2);
  surface1: $(hex surface1);
  surface0: $(hex surface0);
  base: $(hex base);
  mantle: $(hex mantle);
  crust: $(hex crust);
}
EOF
echo "  rofi colors.rasi"

# ── 4. Fish — include file (auto-sourced from conf.d) ───────────────────────
cat > "$DOTFILES/fish/.config/fish/conf.d/theme_colors.fish" << EOF
# Generated by theme-apply — do not edit
set -g thm_blue ${C[blue]}
set -g thm_overlay ${C[subtext0]}
set -g thm_yellow ${C[yellow]}
set -g thm_green ${C[green]}
set -g thm_red ${C[red]}
EOF
echo "  fish theme_colors.fish"

# ── 5. Tmux — sourced BEFORE catppuccin plugin (plugin uses set -o) ─────────
cat > "$DOTFILES/theme/.config/theme/tmux-colors.conf" << EOF
# Generated by theme-apply — do not edit
# Source BEFORE catppuccin plugin; it uses set -ogq so these take precedence
set -gq @thm_bg "$(hex base)"
set -gq @thm_fg "$(hex text)"
set -gq @thm_rosewater "$(hex rosewater)"
set -gq @thm_flamingo "$(hex flamingo)"
set -gq @thm_pink "$(hex pink)"
set -gq @thm_mauve "$(hex mauve)"
set -gq @thm_red "$(hex red)"
set -gq @thm_maroon "$(hex maroon)"
set -gq @thm_peach "$(hex peach)"
set -gq @thm_yellow "$(hex yellow)"
set -gq @thm_green "$(hex green)"
set -gq @thm_teal "$(hex teal)"
set -gq @thm_sky "$(hex sky)"
set -gq @thm_sapphire "$(hex sapphire)"
set -gq @thm_blue "$(hex blue)"
set -gq @thm_lavender "$(hex lavender)"
set -gq @thm_subtext_1 "$(hex subtext0)"
set -gq @thm_subtext_0 "$(hex subtext1)"
set -gq @thm_overlay_2 "$(hex overlay2)"
set -gq @thm_overlay_1 "$(hex overlay1)"
set -gq @thm_overlay_0 "$(hex overlay0)"
set -gq @thm_surface_2 "$(hex surface2)"
set -gq @thm_surface_1 "$(hex surface1)"
set -gq @thm_surface_0 "$(hex surface0)"
set -gq @thm_mantle "$(hex mantle)"
set -gq @thm_crust "$(hex crust)"
EOF
echo "  tmux-colors.conf"

# ── 6. Nvim — catppuccin color_overrides Lua table ──────────────────────────
mkdir -p "$DOTFILES/nvim/.config/nvim/lua"
cat > "$DOTFILES/nvim/.config/nvim/lua/theme_colors.lua" << EOF
-- Generated by theme-apply — do not edit
return {
  base = "$(hex base)",
  mantle = "$(hex mantle)",
  crust = "$(hex crust)",
  text = "$(hex text)",
  subtext1 = "$(hex subtext1)",
  subtext0 = "$(hex subtext0)",
  surface0 = "$(hex surface0)",
  surface1 = "$(hex surface1)",
  surface2 = "$(hex surface2)",
  overlay0 = "$(hex overlay0)",
  overlay1 = "$(hex overlay1)",
  overlay2 = "$(hex overlay2)",
  blue = "$(hex blue)",
  lavender = "$(hex lavender)",
  sapphire = "$(hex sapphire)",
  sky = "$(hex sky)",
  teal = "$(hex teal)",
  green = "$(hex green)",
  yellow = "$(hex yellow)",
  peach = "$(hex peach)",
  maroon = "$(hex maroon)",
  red = "$(hex red)",
  mauve = "$(hex mauve)",
  pink = "$(hex pink)",
  flamingo = "$(hex flamingo)",
  rosewater = "$(hex rosewater)",
}
EOF
echo "  nvim theme_colors.lua"

# ── 7. Mako — sed replacement (no include support) ──────────────────────────
MAKO="$DOTFILES/mako/.config/mako/config"
if [[ -f "$MAKO" ]]; then
  # Read current palette from mako (extract unique 6-char hex after #)
  MAKO_PREV="$DOTFILES/theme/.config/theme/.mako-colors"
  if [[ -f "$MAKO_PREV" ]]; then
    while IFS='=' read -r role old_hex; do
      [[ -z "$role" || -z "$old_hex" ]] && continue
      new_hex="${C[$role]:-}"
      [[ -z "$new_hex" || "$old_hex" == "$new_hex" ]] && continue
      sed -i "s/#${old_hex}/#${new_hex}/gi" "$MAKO"
    done < "$MAKO_PREV"
  fi
  # Save current colors for next run
  for r in "${ROLES[@]}"; do
    echo "$r=${C[$r]}"
  done > "$MAKO_PREV"
  echo "  mako config (sed)"
fi

# ── 8. Waybar CSS — sed replacement (hex + rgba decimal) ─────────────────────
WAYBAR="$DOTFILES/waybar/.config/waybar/style.css"
if [[ -f "$WAYBAR" ]]; then
  WAYBAR_PREV="$DOTFILES/theme/.config/theme/.waybar-colors"
  if [[ -f "$WAYBAR_PREV" ]]; then
    while IFS='=' read -r role old_hex; do
      [[ -z "$role" || -z "$old_hex" ]] && continue
      new_hex="${C[$role]:-}"
      [[ -z "$new_hex" || "$old_hex" == "$new_hex" ]] && continue
      # Hex replacement
      sed -i "s/${old_hex}/${new_hex}/gi" "$WAYBAR"
      # Decimal rgba() replacement (handles "r, g, b" with spaces)
      old_r=$((16#${old_hex:0:2})); old_g=$((16#${old_hex:2:2})); old_b=$((16#${old_hex:4:2}))
      new_r=$((16#${new_hex:0:2})); new_g=$((16#${new_hex:2:2})); new_b=$((16#${new_hex:4:2}))
      sed -i "s/${old_r}, *${old_g}, *${old_b}/${new_r}, ${new_g}, ${new_b}/g" "$WAYBAR"
    done < "$WAYBAR_PREV"
  fi
  for r in "${ROLES[@]}"; do
    echo "$r=${C[$r]}"
  done > "$WAYBAR_PREV"
  echo "  waybar style.css (sed)"
fi

# ── 9. Hyprland conf — sed for rgba decimal colors ──────────────────────────
HYPR="$DOTFILES/hypr/.config/hypr/hyprland.conf"
if [[ -f "$HYPR" ]]; then
  HYPR_PREV="$DOTFILES/theme/.config/theme/.hypr-colors"
  if [[ -f "$HYPR_PREV" ]]; then
    while IFS='=' read -r role old_hex; do
      [[ -z "$role" || -z "$old_hex" ]] && continue
      new_hex="${C[$role]:-}"
      [[ -z "$new_hex" || "$old_hex" == "$new_hex" ]] && continue
      # Convert to decimal for rgba() replacements
      old_r=$((16#${old_hex:0:2})); old_g=$((16#${old_hex:2:2})); old_b=$((16#${old_hex:4:2}))
      new_r=$((16#${new_hex:0:2})); new_g=$((16#${new_hex:2:2})); new_b=$((16#${new_hex:4:2}))
      sed -i "s/${old_r},${old_g},${old_b}/${new_r},${new_g},${new_b}/g" "$HYPR"
    done < "$HYPR_PREV"
  fi
  for r in "${ROLES[@]}"; do
    echo "$r=${C[$r]}"
  done > "$HYPR_PREV"
  echo "  hyprland.conf (sed rgba)"
fi

# ── 10. Regenerate gallery HTML from presets ─────────────────────────────────
GALLERY="$DOTFILES/theme/.config/theme/gallery.html"
GALLERY_PRESETS=""
for pf in "$DOTFILES/theme/.config/theme/presets"/*; do
  [[ -L "$pf" ]] && continue
  pname=$(basename "$pf")
  pdesc=$(head -1 "$pf" | sed 's/^# *//')
  # Read colors into JSON object
  colors="{"
  while IFS='=' read -r k v; do
    [[ -z "$k" || "$k" =~ ^# ]] && continue
    colors+="\"$k\":\"$v\","
  done < "$pf"
  colors="${colors%,}}"
  GALLERY_PRESETS+="  { name: \"$pname\", desc: \"$pdesc\", colors: $colors },
"
done

cat > "$GALLERY" << 'GALLERY_HEAD'
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Forest Theme Gallery</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'JetBrains Mono', 'Fira Code', monospace; background: #111; color: #ccc; padding: 1.5rem; }
  h1 { font-size: 1.1rem; margin-bottom: 0.2rem; }
  .subtitle { color: #888; margin-bottom: 1.5rem; font-size: 0.8rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(500px, 1fr)); gap: 1.5rem; }
  .card { border: 2px solid #333; border-radius: 14px; overflow: hidden; cursor: pointer; transition: border-color 0.2s; }
  .card:hover { border-color: #666; }
  .card.selected { border-color: #6daa8e; box-shadow: 0 0 20px rgba(109,170,142,0.2); }
  .card-header { padding: 10px 16px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; background: #1a1a1a; }
  .card-header h2 { font-size: 0.85rem; }
  .swatches { display: flex; height: 5px; }
  .swatches div { flex: 1; }
  .hypr-window { margin: 12px; border-radius: 10px; overflow: hidden; border-width: 2px; border-style: solid; }
  .terminal-body { padding: 12px 16px; font-size: 0.78rem; line-height: 1.55; }
  .t-line { display: inline-block; width: 2em; text-align: right; margin-right: 0.8em; user-select: none; }
  .waybar-mock { margin: 0 12px; border-radius: 10px; padding: 5px 12px; display: flex; justify-content: space-between; font-size: 0.75rem; }
  .wb-pill { padding: 1px 8px; border-radius: 8px; margin: 0 1px; display: inline-block; }
  .wb-left, .wb-right { display: flex; gap: 2px; align-items: center; }
  .notif-row { display: flex; gap: 8px; justify-content: flex-end; margin: 8px 12px; }
  .notif-mock { border-radius: 10px; padding: 8px 12px; border-left: 3px solid; max-width: 260px; }
  .notif-title { font-weight: bold; font-size: 0.72rem; }
  .notif-body { font-size: 0.68rem; }
  .cmd { margin: 8px 12px 12px; padding: 4px 10px; border-radius: 6px; font-size: 0.68rem; }
  .cmd code { opacity: 0.7; }
  #output { position: fixed; bottom: 1rem; left: 50%; transform: translateX(-50%); background: #1a3a1e; color: #8f8; padding: 10px 20px; border-radius: 8px; font-size: 0.8rem; display: none; z-index: 10; }
</style>
</head>
<body>
<h1>Forest Theme Gallery</h1>
<p class="subtitle">Click a preset to copy the switch command. Use <code>Super+Alt+T</code> to open the rofi picker.</p>
<div class="grid" id="grid"></div>
<div id="output"></div>
<script>
GALLERY_HEAD

# Inject presets data
echo "const PRESETS = [" >> "$GALLERY"
echo "$GALLERY_PRESETS" >> "$GALLERY"
echo "];" >> "$GALLERY"

cat >> "$GALLERY" << 'GALLERY_TAIL'
function h(c, r) { return '#' + c[r]; }
function renderCard(p, i) {
  const c = p.colors;
  const card = document.createElement('div');
  card.className = 'card'; card.id = 'card-'+i;
  card.onclick = () => selectCard(i);
  const accents = ['blue','green','yellow','red','mauve','teal','peach','sapphire'];
  card.innerHTML = `
    <div class="card-header"><h2>${p.name}</h2></div>
    <div class="swatches">${accents.map(k=>`<div style="background:${h(c,k)}"></div>`).join('')}</div>
    <div class="card-body">
      <div class="hypr-window" style="background:${h(c,'base')};border-color:${h(c,'blue')}">
        <div class="terminal-body">
          <div><span class="t-line" style="color:${h(c,'overlay0')}">1</span><span style="color:${h(c,'mauve')}">import</span> <span style="color:${h(c,'teal')}">json</span></div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">2</span><span style="color:${h(c,'mauve')}">from</span> <span style="color:${h(c,'teal')}">pathlib</span> <span style="color:${h(c,'mauve')}">import</span> <span style="color:${h(c,'teal')}">Path</span></div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">3</span></div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">4</span><span style="color:${h(c,'overlay2')}">// Load the forest palette</span></div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">5</span><span style="color:${h(c,'mauve')}">def</span> <span style="color:${h(c,'blue')}">load_palette</span>(<span style="color:${h(c,'peach')}">path</span>: <span style="color:${h(c,'teal')}">str</span>):</div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">6</span>    <span style="color:${h(c,'mauve')}">with</span> <span style="color:${h(c,'blue')}">open</span>(<span style="color:${h(c,'peach')}">path</span>) <span style="color:${h(c,'mauve')}">as</span> f:</div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">7</span>        <span style="color:${h(c,'mauve')}">return</span> <span style="color:${h(c,'teal')}">json</span>.<span style="color:${h(c,'blue')}">load</span>(f)</div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">8</span>N = <span style="color:${h(c,'yellow')}">26</span></div>
          <div><span class="t-line" style="color:${h(c,'overlay0')}">9</span><span style="color:${h(c,'red')}">raise</span> <span style="color:${h(c,'red')}">ValueError</span>(<span style="color:${h(c,'green')}">"Missing"</span>)</div>
        </div>
      </div>
      <div class="waybar-mock" style="background:${h(c,'mantle')}e6">
        <div class="wb-left">
          <span class="wb-pill" style="background:${h(c,'blue')}26;color:${h(c,'blue')};border-bottom:2px solid ${h(c,'blue')}">  1</span>
          <span class="wb-pill" style="color:${h(c,'overlay0')}">  2</span>
        </div>
        <span style="color:${h(c,'text')};font-weight:bold">Sat 29 Mar  14:32</span>
        <div class="wb-right">
          <span class="wb-pill" style="background:${h(c,'surface0')}99;color:${h(c,'yellow')}"> 65%</span>
          <span class="wb-pill" style="background:${h(c,'surface0')}99;color:${h(c,'green')}"> 87%</span>
        </div>
      </div>
      <div class="notif-row">
        <div class="notif-mock" style="background:${h(c,'base')}e6;border-left-color:${h(c,'blue')}">
          <div class="notif-title" style="color:${h(c,'text')}">Claude finished</div>
          <div class="notif-body" style="color:${h(c,'subtext0')}">Refactored module...</div>
        </div>
        <div class="notif-mock" style="background:${h(c,'base')}e6;border-left-color:${h(c,'red')}">
          <div class="notif-title" style="color:${h(c,'text')}">Battery Low</div>
          <div class="notif-body" style="color:${h(c,'subtext0')}">10% remaining</div>
        </div>
      </div>
      <div class="cmd" style="background:${h(c,'crust')}">
        <code style="color:${h(c,'overlay2')}">theme-switch ${p.name}</code>
      </div>
    </div>`;
  return card;
}
function selectCard(i) {
  document.querySelectorAll('.card').forEach(c => c.classList.remove('selected'));
  document.getElementById('card-'+i).classList.add('selected');
  const cmd = 'theme-switch ' + PRESETS[i].name;
  navigator.clipboard.writeText(cmd);
  const out = document.getElementById('output');
  out.textContent = 'Copied: ' + cmd;
  out.style.display = 'block';
  setTimeout(() => out.style.display = 'none', 2000);
}
PRESETS.forEach((p, i) => document.getElementById('grid').appendChild(renderCard(p, i)));
</script>
</body>
</html>
GALLERY_TAIL
echo "  gallery.html"

# ── Re-stow packages with new generated files ──────────────────────────────
(cd "$DOTFILES" && stow -R hypr kitty rofi nvim theme 2>/dev/null) || true

# ── Reload running services ─────────────────────────────────────────────────
echo "Reloading..."

if pgrep -x Hyprland >/dev/null 2>&1; then
  hyprctl reload 2>/dev/null || true
  pkill waybar 2>/dev/null; sleep 0.3
  waybar 2>&1 | grep -v 'Gtk-CRITICAL\|GTK_IS_ACCEL_GROUP' &disown 2>/dev/null
  makoctl reload 2>/dev/null || true
fi

for sock in /tmp/kitty-*; do
  kitty @ --to "unix:$sock" set-colors --all --configured \
    "$HOME/.config/kitty/colors.conf" 2>/dev/null || true
done

tmux source-file ~/.tmux.conf 2>/dev/null || true

for addr in $(find /run/user/"$(id -u)"/ /tmp/ -name 'nvim.*' -type s 2>/dev/null); do
  nvim --server "$addr" --remote-send \
    ":lua require('catppuccin').setup{color_overrides={all=require('theme_colors')},no_italic=true} vim.cmd.colorscheme'catppuccin'<CR>" \
    2>/dev/null || true
done

echo "Done."
