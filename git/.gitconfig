[user]
	email = jaeho2025@gmail.com
	name = Jaeho Cho
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/usr/bin/gh auth git-credential
[core]
	editor = nvim
	hooksPath = ~/.git-hooks
	pager = diff-highlight | less
[pull]
	rebase = false
[push]
	autoSetupRemote = true
[diff]
	colorMoved = default
[color "diff"]
	meta = 111
	old = 174
	new = 150
	frag = 183 bold
[color "diff-highlight"]
	oldNormal = 174
	oldHighlight = 174 bold 52
	newNormal = 150
	newHighlight = 150 bold 22
[alias]
	co = checkout
	br = branch
	ci = commit
	st = !git fetch --all && git status
	unstage = reset HEAD --
	lg = log --all --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'
