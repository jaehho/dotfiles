# Mako notification daemon — colors applied by theme-apply

# Appearance
font=JetBrainsMono Nerd Font 11
background-color=#303446E6
text-color=#c6d0f5
border-color=#8caaeeCC
border-size=2
border-radius=12
width=380
padding=12
margin=10

# Behavior
default-timeout=5000
layer=overlay
anchor=top-right
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48

# Progress bar (volume/brightness OSD)
progress-color=source #8caaee

# Do-not-disturb mode
[mode=do-not-disturb]
invisible=1

# Urgency overrides
[urgency=low]
border-color=#a6d189CC
default-timeout=3000

[urgency=normal]
border-color=#8caaeeCC
default-timeout=5000

[urgency=high]
border-color=#e78284CC
default-timeout=0

# Persistent normal notification (blue border, no timeout)
# Usage: notify-send -c persistent "Title" "Body"
[category=persistent]
default-timeout=0

# Click Claude Code notifications to focus the terminal running Claude
[app-name="Claude Code"]
on-button-left=invoke-default-action
default-timeout=0

# SSH Claude notifications arrive via Kitty's OSC 99 (app-name="kitty")
[app-name="kitty" summary~="Claude"]
default-timeout=0
on-button-left=dismiss

# Spotify — green border, group track changes so skips replace not stack
[app-name=spotify_player]
default-timeout=5000
border-color=#a6d189CC
group-by=app-name

# Thunderbird — purple border for new mail
[app-name=thunderbird]
default-timeout=8000
border-color=#ca9ee6CC
group-by=app-name

# Teams — purple border, longer timeout for messages
[app-name="Microsoft Teams*"]
default-timeout=10000
border-color=#ca9ee6CC
group-by=app-name
on-button-left=exec hyprctl dispatch focuswindow class:teams-for-linux
