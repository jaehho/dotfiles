#!/bin/bash
# hypr-monitor-hotplug — dynamic workspace distribution based on connected monitors
#
# Scenarios:
#   Laptop only (1 monitor):       WS 1-10 on eDP-1
#   Laptop + 1 external (2 mon):   odd on external, even on laptop (1,3,5,7,9 / 2,4,6,8,10)
#   Laptop + 2 externals (3 mon):  round-robin (1,4,7,10 / 2,5,8 / 3,6,9)
#
# Usage:
#   hypr-monitor-hotplug assign   — redistribute workspaces now
#   hypr-monitor-hotplug watch    — listen for hotplug events and auto-redistribute

LAPTOP_PATTERN="BOE"

get_monitors() {
    hyprctl monitors -j | jq -r '.[].name'
}

is_laptop() {
    local mon="$1"
    hyprctl monitors -j | jq -r --arg name "$mon" \
        '.[] | select(.name == $name) | .description' | grep -qi "$LAPTOP_PATTERN"
}

assign_workspaces() {
    local laptop_mon=""
    local -a ext_mons=()

    while IFS= read -r mon; do
        if is_laptop "$mon"; then
            laptop_mon="$mon"
        else
            ext_mons+=("$mon")
        fi
    done < <(get_monitors)

    # Fallback: if no laptop detected, treat first monitor as "laptop"
    if [[ -z "$laptop_mon" ]]; then
        laptop_mon="${ext_mons[0]}"
        ext_mons=("${ext_mons[@]:1}")
    fi

    local count=$(( ${#ext_mons[@]} + 1 ))

    # Build ordered monitor list: externals first, laptop last
    local -a all_mons=("${ext_mons[@]}" "$laptop_mon")

    # Round-robin (collated) distribution: WS 1→mon0, 2→mon1, 3→mon2, 4→mon0, ...
    local -a first_ws_on_mon=()
    for ws in $(seq 1 10); do
        local idx=$(( (ws - 1) % count ))
        local mon="${all_mons[$idx]}"
        hyprctl keyword workspace "$ws,monitor:$mon" >/dev/null
        hyprctl dispatch moveworkspacetomonitor "$ws $mon" >/dev/null 2>&1
        # Track first workspace per monitor for default:true
        if [[ -z "${first_ws_on_mon[$idx]}" ]]; then
            first_ws_on_mon[$idx]=$ws
        fi
    done

    # Set default workspace per monitor
    for ((i=0; i<count; i++)); do
        local ws="${first_ws_on_mon[$i]}"
        local mon="${all_mons[$i]}"
        hyprctl keyword workspace "$ws,monitor:$mon,default:true" >/dev/null
    done

    notify-send -u low -t 3000 \
        -h "string:x-canonical-private-synchronous:hypr-hotplug" \
        "Monitors: $count" "Workspaces redistributed"
}

find_socket() {
    if [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
        echo "${XDG_RUNTIME_DIR}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"
    else
        find "${XDG_RUNTIME_DIR}/hypr/" -name ".socket2.sock" -print -quit 2>/dev/null
    fi
}

case "${1:-assign}" in
    assign)
        assign_workspaces
        ;;
    watch)
        # Initial assignment
        assign_workspaces
        # Listen for monitor events via Hyprland socket2
        sock="$(find_socket)"
        if [[ -z "$sock" || ! -S "$sock" ]]; then
            echo "Error: Hyprland socket not found" >&2
            exit 1
        fi
        socat -U - "UNIX-CONNECT:$sock" | {
            last_event=0
            while IFS= read -r line; do
                case "$line" in
                    monitoradded*|monitorremoved*)
                        now=$(date +%s)
                        if ((now - last_event >= 3)); then
                            last_event=$now
                            sleep 2
                            assign_workspaces
                        fi
                        ;;
                esac
            done
        }
        ;;
    *)
        echo "Usage: $(basename "$0") [assign|watch]"
        echo "  assign  — redistribute workspaces now (default)"
        echo "  watch   — listen for hotplug events and auto-redistribute"
        exit 1
        ;;
esac
