#!/bin/bash
# Output waybar JSON for a special workspace, mapping window classes to nerd font glyphs.
# Usage: hypr-special-waybar <workspace-name> <workspace-icon>
# Example: hypr-special-waybar 'special:¾░śĖ' '¾░śĖ'

WS_NAME="$1"
WS_ICON="$2"

class_to_glyph() {
    case "$1" in
        kitty|foot|Alacritty) echo -n "¾░äø" ;;
        firefox*) echo -n "¾░ł╣" ;;
        chromium) echo -n "¾░Ŗ»" ;;
        org.mozilla.Thunderbird) echo -n "¾░║╗" ;;
        Zotero) echo -n "¾▒ē¤" ;;
        spotify_player) echo -n "¾░ōć" ;;
        teams-for-linux) echo -n "¾░Ŗ╗" ;;
        code*) echo -n "¾░©×" ;;
        discord|vesktop) echo -n "¾░Ö»" ;;
        Slack) echo -n "¾░Æ▒" ;;
        org.pwmt.zathura) echo -n "¾░łÖ" ;;
        mpv|vlc) echo -n "¾░Éī" ;;
        obsidian) echo -n "¾░Ä×" ;;
        thunar|nautilus) echo -n "¾░ēŗ" ;;
        pavucontrol|wiremix) echo -n "¾░ĢŠ" ;;
        *) echo -n "¾░ÅŚ" ;;
    esac
}

clients=$(hyprctl clients -j | jq -r --arg ws "$WS_NAME" '[.[] | select(.workspace.name == $ws) | .class] | .[]')

if [ -z "$clients" ]; then
    echo '{}'
    exit 0
fi

text="$WS_ICON"
tooltip=""
while IFS= read -r class; do
    text+=" $(class_to_glyph "$class")"
    [ -n "$tooltip" ] && tooltip+=", "
    tooltip+="$class"
done <<< "$clients"

# Check if this special workspace overlay is visible on THIS monitor
visible=$(hyprctl monitors -j | jq -r --arg ws "$WS_NAME" --arg mon "$WAYBAR_OUTPUT_NAME" '.[] | select(.name == $mon) | .specialWorkspace.name == $ws')
if [ "$visible" = "true" ]; then
    css_class="active"
else
    css_class=""
fi

printf '{"text": "%s", "tooltip": "%s", "class": "%s"}\n' "$text" "$tooltip" "$css_class"
