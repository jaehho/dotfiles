#!/usr/bin/env bash
# Open qalc. If focused window's process tree contains a tmux client,
# split a pane there. Otherwise focus an existing floating qalc, or launch one.
set -euo pipefail

QALC_CLASS="floating-qalc"
FLOAT_CMD=(kitty --class "$QALC_CLASS" -e qalc)

launch_or_focus_float() {
    local addr
    addr=$(hyprctl clients -j 2>/dev/null \
        | jq -r --arg c "$QALC_CLASS" 'map(select(.class==$c)) | .[0].address // ""')
    if [ -n "$addr" ]; then
        exec hyprctl dispatch focuswindow "address:$addr"
    fi
    exec "${FLOAT_CMD[@]}"
}

active=$(hyprctl activewindow -j 2>/dev/null || echo '{}')
pid=$(printf '%s' "$active" | jq -r '.pid // 0')

[ "$pid" -gt 0 ] || launch_or_focus_float

# Collect all descendants of the focused window.
descendants() {
    local p=$1 kids k
    kids=$(pgrep -P "$p" 2>/dev/null || true)
    for k in $kids; do
        printf '%s\n' "$k"
        descendants "$k"
    done
}

# Find a tmux client (not server) anywhere in the focused window's subtree.
# This works regardless of terminal class — if tmux is running there, we use it.
tmux_tty=""
while read -r p; do
    [ -z "$p" ] && continue
    comm=$(ps -p "$p" -o comm= 2>/dev/null || true)
    case "$comm" in
        tmux|tmux:*)
            t=$(ps -p "$p" -o tty= 2>/dev/null | tr -d ' ')
            if [ -n "$t" ] && [ "$t" != "?" ]; then
                tmux_tty="/dev/$t"
                break
            fi
            ;;
    esac
done < <(descendants "$pid")

if [ -n "$tmux_tty" ]; then
    session=$(tmux list-clients -F '#{client_tty}|#{session_name}' 2>/dev/null \
        | awk -F'|' -v tty="$tmux_tty" '$1==tty {print $2; exit}')
    if [ -n "$session" ]; then
        # Dwindle-style: split the longer pixel dimension. Character cells are
        # ~2:1 tall:wide, so width > 2*height means the pane is wider in pixels.
        read -r w h < <(tmux display -t "$session" -p -F '#{pane_width} #{pane_height}' 2>/dev/null || echo '0 0')
        if [ "${w:-0}" -gt $(( ${h:-0} * 2 )) ]; then
            split_flag="-h"   # side by side
        else
            split_flag="-v"   # stacked
        fi
        exec tmux split-window "$split_flag" -t "$session" qalc
    fi
fi

launch_or_focus_float
