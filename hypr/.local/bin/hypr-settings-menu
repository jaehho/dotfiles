#!/usr/bin/env bash
# Quick settings menu via rofi â€” central hub for system GUIs

choice=$(printf '%s\n' \
    "َ°¤¨  Wi-Fi" \
    "َ°‚¯  Bluetooth" \
    "َ°•¾  Audio" \
    "َ°چ¹  Display" \
    "  Appearance" \
    "َ°چ›  System Monitor" \
    | rofi -dmenu -p "Settings" -theme-str 'listview { lines: 6; }')

[[ -z "$choice" ]] && exit 0

gui() { "$@" &>/dev/null & disown; }
tui() { kitty --class floating-tui -e "$@"; }

case "$choice" in
    *Wi-Fi*)       tui nmtui ;;
    *Bluetooth*)   gui blueman-manager ;;
    *Audio*)       gui pavucontrol ;;
    *Display*)     gui nwg-displays ;;
    *Appearance*)  gui nwg-look ;;
    *System*)      tui btop ;;
esac
