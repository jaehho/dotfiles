# Cooper University servers
# Requires sshpass: pacman -S sshpass
# Password stored in ~/.ssh/jump_pass (gitignored, chmod 600)
# To set up: echo 'YOUR_PASSWORD' > ~/.ssh/jump_pass && chmod 600 ~/.ssh/jump_pass

Host ice
    HostName ice00.ee.cooper.edu
    Port 31415
    User jaeho.cho
    ConnectTimeout 10
    ServerAliveInterval 15
    ServerAliveCountMax 3

Host mililab
    HostName 10.5.1.124
    User jaeho
    ConnectTimeout 10
    ServerAliveInterval 15
    ServerAliveCountMax 3
    ProxyCommand sshpass -f ~/.ssh/jump_pass ssh -o ConnectTimeout=10 -o ServerAliveInterval=15 -o ServerAliveCountMax=3 -p 31415 -W %h:%p jaeho.cho@dev.ee.cooper.edu
