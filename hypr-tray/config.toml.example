# hypr-tray config — managed apps get tray icons and process supervision
# Place at: ~/.config/hypr-tray/config.toml

# Apps WITHOUT native tray support — hypr-tray manages them
[apps.thunderbird]
command = "thunderbird"
class = "org.mozilla.Thunderbird"
icon = "org.mozilla.Thunderbird"
restart = true          # restart if killed (e.g. CSD close button)

[apps.zotero]
command = "zotero"
class = "Zotero"
icon = "zotero"
restart = true

# Apps WITH native tray — hypr-tray leaves them alone
# Listed here so `hypr-tray status` can report on them
[apps.teams]
command = "teams-for-linux"
class = "teams-for-linux"
has_tray = true
